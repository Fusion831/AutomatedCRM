{
  "name": "contacts",
  "primary_key_column": "id",
  "enable_rls": false,
  "visibility": "POD",
  "columns": [
    {
      "name": "name",
      "type": "TEXT",
      "required": true
    },
    {
      "name": "relationship_state",
      "type": "ENUM",
      "required": true,
      "default": "mutual_exploration",
      "options": [
        "waiting_on_me",
        "waiting_on_them",
        "mutual_exploration",
        "blocked",
        "cooling",
        "reengagement_candidate"
      ]
    },
    {
      "name": "tier",
      "type": "ENUM",
      "required": true,
      "default": "B",
      "options": [
        "A",
        "B",
        "C"
      ]
    },
    {
      "name": "who_are_they",
      "type": "TEXT",
      "required": false
    },
    {
      "name": "why_talking",
      "type": "TEXT",
      "required": false
    },
    {
      "name": "key_drivers",
      "type": "JSON",
      "required": false
    },
    {
      "name": "memory_confidence",
      "type": "JSON",
      "required": false
    },
    {
      "name": "priority_score",
      "type": "INTEGER",
      "required": true,
      "default": 0
    },
    {
      "name": "priority_reasons",
      "type": "JSON",
      "required": false
    },
    {
      "name": "last_interaction",
      "type": "DATETIME",
      "required": false
    },
    {
      "name": "expected_next_touch_date",
      "type": "DATE",
      "required": false
    },
    {
      "name": "attention_level",
      "type": "ENUM",
      "required": false,
      "default": "LOW",
      "options": [
        "LOW",
        "MEDIUM",
        "HIGH",
        "CRITICAL"
      ]
    },
    {
      "name": "recommended_action",
      "type": "TEXT",
      "required": false
    },
    {
      "name": "recommendation_category",
      "type": "ENUM",
      "required": false,
      "options": [
        "FOLLOW_UP",
        "SEND_DOCUMENT",
        "SCHEDULE_MEETING",
        "RESPOND",
        "WAIT",
        "REENGAGE",
        "RESOLVE_BLOCKER",
        "CLOSE_LOOP",
        "NO_ACTION"
      ]
    },
    {
      "name": "recommendation_urgency",
      "type": "ENUM",
      "required": false,
      "options": [
        "LOW",
        "MEDIUM",
        "HIGH",
        "CRITICAL"
      ]
    },
    {
      "name": "recommendation_reasoning",
      "type": "JSON",
      "required": false
    },
    {
      "name": "recommendation_evidence",
      "type": "JSON",
      "required": false
    }
  ],
  "config": {}
}
