        "resource_type": "datastore_table",
        "resource_name": "contacts",
        "permission_ids": ["datastore.table.read", "datastore.record.read"]
      },
      {
        "resource_type": "datastore_table",
        "resource_name": "commitments",
        "permission_ids": ["datastore.table.read", "datastore.record.read"]
      },
      {
        "resource_type": "datastore_table",
        "resource_name": "interactions",
        "permission_ids": ["datastore.table.read", "datastore.record.read"]
      },
      {
        "resource_type": "datastore_table",
        "resource_name": "open_loop_health",
        "permission_ids": ["datastore.table.read", "datastore.record.read"]
      },
      {
        "resource_type": "datastore_table",
        "resource_name": "daily_briefs",
        "permission_ids": ["datastore.table.read", "datastore.record.read", "datastore.record.write"]
      },
      {
        "resource_type": "datastore_table",
        "resource_name": "command_center_snapshots",
        "permission_ids": ["datastore.table.read", "datastore.record.read", "datastore.record.write"]
      }
    ]
