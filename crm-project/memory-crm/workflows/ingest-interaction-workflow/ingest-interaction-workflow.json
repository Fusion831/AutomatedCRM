{
  "name": "ingest-interaction-workflow",
  "description": "Triggered by new interaction inserts. Prepares contact context, invokes consolidated-extractor, reconciles commitments, saves updates, evaluates relationship state, updates priority score, generates recommendations, rebuilds the context resurrection cache, evaluates open loops health, and refreshes the daily command center snapshot.",
  "visibility": "POD",
  "start": {
    "type": "DATASTORE_EVENT",
    "config": {
      "table_name": "interactions",
      "operations": [
        "INSERT"
      ]
    }
  },
  "nodes": [
    {
      "id": "fetch_context",
      "type": "FUNCTION",
      "label": "Fetch Contact Context",
      "config": {
        "function_name": "fetch_context_function",
        "input_mapping": {
          "interaction": {
            "type": "expression",
            "value": "start.payload"
          }
        }
      }
    },
    {
      "id": "extractor",
      "type": "AGENT",
      "label": "Consolidated Extractor Agent",
      "config": {
        "agent_name": "consolidated-extractor",
        "input_mapping": {
          "contact_memory": {
            "type": "expression",
            "value": "fetch_context.output.contact_memory"
          },
          "open_commitments": {
            "type": "expression",
            "value": "fetch_context.output.open_commitments"
          },
          "new_interaction": {
            "type": "expression",
            "value": "fetch_context.output.new_interaction"
          }
        }
      }
    },
    {
      "id": "reconciliation",
      "type": "FUNCTION",
      "label": "Reconcile Commitments",
      "config": {
        "function_name": "reconcile_commitments_function",
        "input_mapping": {
          "reconciliations": {
            "type": "expression",
            "value": "extractor.output.reconciliations"
          },
          "new_interaction_content": {
            "type": "expression",
            "value": "fetch_context.output.new_interaction.content"
          }
        }
      }
    },
    {
      "id": "apply_updates",
      "type": "FUNCTION",
      "label": "Apply Memory & Commitment Updates",
      "config": {
        "function_name": "apply_updates_function",
        "input_mapping": {
          "contact_id": {
            "type": "expression",
            "value": "fetch_context.output.contact_id"
          },
          "interaction_id": {
            "type": "expression",
            "value": "fetch_context.output.interaction_id"
          },
          "extraction_result": {
            "type": "expression",
            "value": "extractor.output"
          },
          "reconciliation_result": {
            "type": "expression",
            "value": "reconciliation.output"
          }
        }
      }
    },
    {
      "id": "state_engine",
      "type": "FUNCTION",
      "label": "Determine Relationship State",
      "config": {
        "function_name": "determine_relationship_state_function",
        "input_mapping": {
          "contact_id": {
            "type": "expression",
            "value": "fetch_context.output.contact_id"
          }
        }
      }
    },
    {
      "id": "priority_engine",
      "type": "FUNCTION",
      "label": "Calculate Contact Priority",
      "config": {
        "function_name": "calculate_contact_priority_function",
        "input_mapping": {
          "contact_id": {
            "type": "expression",
            "value": "fetch_context.output.contact_id"
          }
        }
      }
    },
    {
      "id": "recommendation_engine",
      "type": "FUNCTION",
      "label": "Generate Contact Recommendation",
      "config": {
        "function_name": "generate_recommendation_function",
        "input_mapping": {
          "contact_id": {
            "type": "expression",
            "value": "fetch_context.output.contact_id"
          }
        }
      }
    },
    {
      "id": "resurrection_snapshot",
      "type": "FUNCTION",
      "label": "Generate Resurrection Snapshot Cache",
      "config": {
        "function_name": "generate_resurrection_snapshot_function",
        "input_mapping": {
          "contact_id": {
            "type": "expression",
            "value": "fetch_context.output.contact_id"
          }
        }
      }
    },
    {
      "id": "evaluate_open_loops",
      "type": "FUNCTION",
      "label": "Evaluate Open Loops Health",
      "config": {
        "function_name": "evaluate_open_loops_function",
        "input_mapping": {
          "contact_id": {
            "type": "expression",
            "value": "fetch_context.output.contact_id"
          }
        }
      }
    },
    {
      "id": "daily_brief",
      "type": "FUNCTION",
      "label": "Generate Daily Summary & Snapshot",
      "config": {
        "function_name": "generate_daily_brief_function",
        "input_mapping": {}
      }
    }
  ],
  "edges": [
    {
      "id": "edge_2",
      "source": "fetch_context",
      "target": "extractor"
    },
    {
      "id": "edge_3",
      "source": "extractor",
      "target": "reconciliation"
    },
    {
      "id": "edge_4",
      "source": "reconciliation",
      "target": "apply_updates"
    },
    {
      "id": "edge_5",
      "source": "apply_updates",
      "target": "state_engine"
    },
    {
      "id": "edge_6",
      "source": "state_engine",
      "target": "priority_engine"
    },
    {
      "id": "edge_7",
      "source": "priority_engine",
      "target": "recommendation_engine"
    },
    {
      "id": "edge_8",
      "source": "recommendation_engine",
      "target": "resurrection_snapshot"
    },
    {
      "id": "edge_9",
      "source": "resurrection_snapshot",
      "target": "evaluate_open_loops"
    },
    {
      "id": "edge_10",
      "source": "evaluate_open_loops",
      "target": "daily_brief"
    }
  ]
}